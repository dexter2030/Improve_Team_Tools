# Skopiuj ten plik do .streamlit/secrets.toml i uzupełnij wartości.
# secrets.toml jest w .gitignore — NIE commituj go.
#
# Na Streamlit Community Cloud te same klucze wpisz w panelu app:
#   Settings → Secrets (interfejs przyjmuje format TOML).

RIOT_API_KEY = "RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Opcjonalnie — bot-password Leaguepedia (wyższy rate limit Cargo API).
# Utwórz na https://lol.fandom.com/Special:BotPasswords
LEAGUEPEDIA_USERNAME = "TwojeKonto@NazwaBota"
LEAGUEPEDIA_PASSWORD = "wygenerowane-haslo-bota"

# Hasło do strony. Bez tego strona jest otwarta dla każdego z linkiem.
APP_PASSWORD = "ustaw-mocne-haslo"
